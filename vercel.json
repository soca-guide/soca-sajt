{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Permissions-Policy", "value": "autoplay=*, encrypted-media=*" },
        { "key": "Cache-Control", "value": "no-cache, must-revalidate" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/admin/partner-entry",  "destination": "/partner-entry/index.html" },
    { "source": "/admin/partner-entry/", "destination": "/partner-entry/index.html" }
  ],
  "crons": [
    {
      "path": "/api/cleanup-lost-found",
      "schedule": "0 3 * * *"
    }
  ]
}
